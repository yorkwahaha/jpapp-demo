      "assets/audio/mentor_m4a/yori-compare-p05.m4a",
      "assets/audio/mentor_m4a/yori-compare-p06.m4a"
    ]
  },
  "NI_FREQUENCY": {
    "dialogue": [
      {
        "text": "又又是「に」呢。都快讓人笑出來了吧。",
        "emotion": "happy"
      },
      {
        "text": "這次這孩子呢，不是在看某一個時刻，而是在看某段時間範圍內會發生幾次的孩子喔。",
        "emotion": "explain"
      },
      {
        "text": "比如說，「一週間に二回運動する（一週運動兩次）」。有個叫做「一週」的容器，而「兩次」被放在裡面──懂那種感覺嗎？「に」就是在支撐著那個容器呢。",
        "emotion": "explain"
      },
      {
        "text": "不是鐘錶上的時間點，而是期間中的次數──在用這種方式計數的時候，這孩子就會登場喔。",
        "emotion": "encourage"
      },
      {
        "text": "……欸，說到「一週兩次」的時候，我每次見到這孩子都會想：一週真的都有好好地七天嗎？待在神殿裡的話，對日子的感覺會變得很模糊呢。",
        "emotion": "think"
      },
      {
        "text": "……你分得清星期幾嗎？我啊，有時候不問旅行者都不會注意到是星期幾呢。",
        "emotion": "embarrassed"
      },
      {
        "text": "……不許笑喔。",
        "emotion": "tsundere"
      }
    ],
    "audio": [
      "assets/audio/mentor_m4a/ni-frequency-p01.m4a",
      "assets/audio/mentor_m4a/ni-frequency-p02.m4a",
      "assets/audio/mentor_m4a/ni-frequency-p03.m4a",
      "assets/audio/mentor_m4a/ni-frequency-p04.m4a",
      "assets/audio/mentor_m4a/ni-frequency-p05.m4a",
      "assets/audio/mentor_m4a/ni-frequency-p06.m4a",
      "assets/audio/mentor_m4a/ni-frequency-p07.m4a"
    ]
  },
  "DE_MATERIAL": {
    "dialogue": [
      {
        "text": "最後一個「で」了。不是表示工具、場所，也不是範圍的那個。",
        "emotion": "gentle"
      },
      {
        "text": "這孩子所看的是材料——會告訴你某樣東西是由什麼誕生出來的孩子喔。",
        "emotion": "explain"
      },
      {
        "text": "比如說，「木で机を作る（用木頭做桌子）」。木頭不是用完就丟掉的東西，而是會成為桌子本身的材料吧。這就是它和「工具」不同的地方。",
        "emotion": "explain"
      },
      {
        "text": "不是「用完就結束」，而是「它改變形態後變成某種東西」——在這種變身的身旁，就有這孩子的存在。",
        "emotion": "encourage"
      },
      {
        "text": "「で」家族的成員，到這裡終於全都見到了呢。你真的很努力，一路分辨到了最後。",
        "emotion": "proud"
      },
      {
        "text": "……欸，再過不久，小助靈們就要全員到齊了喔！終於，全員。好開心，真的……我一直以來都只盼望著這件事。",
        "emotion": "happy"
      },
      {
        "text": "……可是，怎麼說呢。總覺得有種奇怪的感覺。……算了，走吧。",
        "emotion": "lonely"
      }
    ],
    "audio": [
      "assets/audio/mentor_m4a/de-material-p01.m4a",
      "assets/audio/mentor_m4a/de-material-p02.m4a",
      "assets/audio/mentor_m4a/de-material-p03.m4a",
      "assets/audio/mentor_m4a/de-material-p04.m4a",
      "assets/audio/mentor_m4a/de-material-p05.m4a",
      "assets/audio/mentor_m4a/de-material-p06.m4a",
      "assets/audio/mentor_m4a/de-material-p07.m4a"
    ]
  },
  "FINAL_BOSS_35": {
    "dialogue": [
      {
        "text": "終於，走到這裡了呢。",
        "emotion": "gentle"
      },
      {
        "text": "看到句子之後，先問問自己吧。這個孩子現在扮演著什麼樣的角色呢──只要這樣就夠了。",
        "emotion": "stage_guide2"
      },
      {
        "text": "來吧，這是最後一道關卡了。抬起頭，向前邁進吧。",
        "emotion": "encourage"
      },
      {
        "text": "……在你出發之前，只讓我說一句話。關於你這個人，一開始我其實並不太信任你。",
        "emotion": "think"
      },
      {
        "text": "老實說就是如此。不過現在……我相信你了。無論是你傾聽聲音的能力，還是一路走來的軌跡，我全都相信。",
        "emotion": "proud"
      },
      {
        "text": "所以……等你回來的時候，我會好好看看你會露出什麼樣的表情。我很期待喔……就只是這樣而已。",
        "emotion": "blessing"
      }
    ],
    "audio": [
      "assets/audio/mentor_m4a/final-boss-35-p01.m4a",
      "assets/audio/mentor_m4a/final-boss-35-p02.m4a",
      "assets/audio/mentor_m4a/final-boss-35-p03.m4a",
      "assets/audio/mentor_m4a/final-boss-35-p04.m4a",
      "assets/audio/mentor_m4a/final-boss-35-p05.m4a",
      "assets/audio/mentor_m4a/final-boss-35-p06.m4a"
    ]
  },
  "ENDING_L35_NORMAL": {
    "dialogue": [
      {
        "text": "……做得很好呢，三十五個試煉，你全都跨越過來了。真的，辛苦你了……你的力量，已經和最初時截然不同了。可以抬頭挺胸、感到驕傲喔。",
        "emotion": "gentle"
      },
      {
        "text": "……有一件事，我先告訴你。這座神殿裡……其實還有一道門存在。那是只有將三十五個試煉全部毫髮無傷地通過的人，才能觸碰到的隱藏封印。",
        "emotion": "proud"
      },
      {
        "text": "如果你心裡有底的話……不妨再回頭看看自己走過的道路吧。",
        "emotion": "explain"
      },
      {
        "text": "……我會一直在這裡。所以，等你回來的時候，我一定會好好迎接你的。",
        "emotion": "gentle"
      }
    ],
    "audio": [
      "assets/audio/mentor_m4a/ending-l35-normal-p01.m4a",
      "assets/audio/mentor_m4a/ending-l35-normal-p02.m4a",
      "assets/audio/mentor_m4a/ending-l35-normal-p03.m4a",
      "assets/audio/mentor_m4a/ending-l35-normal-p04.m4a"
    ]
  },
  "ENDING_L35_ALL_S": {
    "dialogue": [
      {
        "text": "……你找到啦。那條隱藏的道路。",
        "emotion": "surprised"
      },
      {
        "text": "三十五個關卡全部，完美的 S 級評價。毫髮無傷地走到了這裡。",
        "emotion": "surprised"
      },
      {
        "text": "……老實說我很驚訝。沒想到竟然會出現這樣的人。真的很高興，發自內心地高興。",
        "emotion": "happy"
      },
      {
        "text": "……但是，如果要繼續前進到這扇門的另一頭，你又要去往更遙遠的地方了呢。雖然我早就知道，不會在這裡就結束……",
        "emotion": "lonely"
      },
      {
        "text": "……可還是覺得有點寂寞。明明花了這麼長的時間，才一路走到這裡。",
        "emotion": "lonely"
      },
      {
        "text": "……去吧。在最後封印的深處，還有人在等著你。",
        "emotion": "concerned"
      },
      {
        "text": "等你回來的時候，一定要讓我看看你平安的樣子……不然我會擔心的。",
        "emotion": "blessing"
      }
    ],
    "audio": [
      "assets/audio/mentor_m4a/ending-l35-all-s-p01.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-p02.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-p03.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-p04.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-p05.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-p06.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-p07.m4a"
    ]
  },
  "ENDING_L35_ALL_S_AT_35": {
    "dialogue": [
      {
        "text": "……你跨越了第三十五個試煉呢。辛苦了。",
        "emotion": "gentle"
      },
      {
        "text": "從一開始到現在，我全都看在眼裡。所以我明白。你的力量，已經是真正貨真價實的了。",
        "emotion": "proud"
      },
      {
        "text": "第三十五關全部，無一例外都是完美的 S 級評價。能看見這扇門的人，只有極少數。你已經成為其中一人了。",
        "emotion": "proud"
      },
      {
        "text": "在最後封印的前方，還有未曾見過的敵人正在等待著。做好萬全準備了嗎，喚語者。",
        "emotion": "blessing"
      },
      {
        "text": "吶……最後說一句。……不要受傷喔……這是命令喔!絕對喔!!",
        "emotion": "concerned"
      }
    ],
    "audio": [
      "assets/audio/mentor_m4a/ending-l35-all-s-at-35-p01.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-at-35-p02.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-at-35-p03.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-at-35-p04.m4a",
      "assets/audio/mentor_m4a/ending-l35-all-s-at-35-p05.m4a"
    ]
  },
  "L36_FIRST_ENTRY": {
    "dialogue": [
      {
        "text": "……終於，來到這一步了呢。三十五道試煉，一個也沒有遺漏地完成了。",
        "emotion": "proud"
      },
      {
        "text": "在前方等待著的，是至今為止遇見的所有聲音交會之處。不是由誰來給你答案，而是要靠你自己的力量，開創最後道路的戰鬥。",
        "emotion": "gentle"
      },
      {
        "text": "……別誤會了，我並不是要消失。只是，你已經成長到即使不依靠我，也能獨自站穩腳步的地步了。那是……一件好事……雖然是好事沒錯。",
        "emotion": "lonely"
      },
      {
        "text": "……吶，等一切都結束之後，那個……。",
        "emotion": "lonely"
      },
      {
        "text": "……路上小心，喚語者。一定要，好好地回來喔。",
        "emotion": "concerned"
      }
    ],
    "audio": [
      "assets/audio/mentor_m4a/l36-first-entry-p01.m4a",
      "assets/audio/mentor_m4a/l36-first-entry-p02.m4a",
      "assets/audio/mentor_m4a/l36-first-entry-p03.m4a",
      "assets/audio/mentor_m4a/l36-first-entry-p04.m4a",
      "assets/audio/mentor_m4a/l36-first-entry-p05.m4a"
    ]
  },
  "HIDDEN_BOSS_36": {
    "dialogue": [
      {
        "text": "……竟然能走到這裡，真的讓我很驚訝呢。",
        "emotion": "surprised"
      },
      {
        "text": "能站在這道封印之前的人，已經不只是個旅人了。這才是真正最後的試煉。",
        "emotion": "gentle"
      },
      {
        "text": "隱藏的王啊，可不會老老實實地把路指給你看。他會把好幾個線索交織在一起，故意讓界線變得難以分辨。",
        "emotion": "concerned"
      },
      {
        "text": "別著急。現在只要看看這段文字正在做什麼——僅此而已。",
        "emotion": "encourage"
      },
      {
        "text": "你已經不是那個什麼都不懂的自己了。",
        "emotion": "proud"
      },
      {
        "text": "……去吧。我會留在這裡，見證你跨越這一切。",
        "emotion": "blessing"
      },
      {
        "text": "……真的，要小心別受傷喔。等你回來的時候，要讓我好好看看你平安無事的模樣才行……不然的話，我可是會傷腦筋的。",
        "emotion": "concerned"
      }
    ],
    "audio": [
      "assets/audio/mentor_m4a/hidden-boss-36-p01.m4a",
      "assets/audio/mentor_m4a/hidden-boss-36-p02.m4a",
      "assets/audio/mentor_m4a/hidden-boss-36-p03.m4a",
      "assets/audio/mentor_m4a/hidden-boss-36-p04.m4a",
      "assets/audio/mentor_m4a/hidden-boss-36-p05.m4a",
      "assets/audio/mentor_m4a/hidden-boss-36-p06.m4a",
      "assets/audio/mentor_m4a/hidden-boss-36-p07.m4a"
    ]
  },
  "FINAL_ENDING": {
    "dialogue": [
      {
        "text": "……你回來了呢。太好了。真的，太好了。",
        "emotion": "happy"
      },
      {
        "text": "我記得最初的你。看起來有些不安，也有些迷惘。而如今，你已經能夠好好接住那失落的聲音了。",
        "emotion": "gentle"
      },
      {
        "text": "你所找回來的，不只是那些小助靈們而已。支撐言語的法理本身，也是你找回的。",
        "emotion": "blessing"
      },
      {
        "text": "謝謝你。謝謝你直到最後都沒有放棄我們。真的，非常謝謝你。",
        "emotion": "gentle"
      },
      {
        "text": "那些被你拯救的小助靈們，已將自己力量的一部分永久託付給你。那不是借來的力量，而是會一直留存在你的言語之中、屬於你自己的力量。",
        "emotion": "explain"
      },
      {
        "text": "所以今後即使遇見更艱深的詞語，也已經不必再害怕了。",
        "emotion": "encourage"
      },
      {
        "text": "……吶。等一切都結束之後，關於那件……我一直想說出口的事，你還記得嗎？",
        "emotion": "lonely"
      },
      {
        "text": "……我果然還是不說了。雖然不說……但如果你已經明白了，我會很高興的。",
        "emotion": "gentle"
      },
      {
        "text": "如果有一天，你覺得助詞們的聲音變得有些遙遠了，隨時都可以回到言葉神殿。我和那些孩子們，都會一直在這裡等著你。",
        "emotion": "gentle"
      },
      {
        "text": "……請一定要好好保重。喚語者。",
        "emotion": "blessing"
      }
    ],
    "audio": [
